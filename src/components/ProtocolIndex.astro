---
import { resourceGroups } from '@data/site';

const protocols = resourceGroups.find((group) => group.group === 'Lab Protocols')?.items ?? [];
const bioinformatics = resourceGroups.find((group) => group.group === 'Bioinformatics')?.items ?? [];
---

<section class="protocol-ledger">
  <div class="protocol-ledger__copy">
    <h2>Protocols are part of the science.</h2>
    <p>
      Students and instructors work from shared lab protocols, bioinformatics chapters, setup notes, and program references.
    </p>
  </div>
  <div class="protocol-ledger__counts" aria-label="Resource count">
    <span><strong>{protocols.length}</strong> lab protocols</span>
    <span><strong>{bioinformatics.length}</strong> bioinformatics chapters</span>
    <span><strong>6</strong> student resources</span>
    <span><strong>4</strong> program references</span>
  </div>
</section>
