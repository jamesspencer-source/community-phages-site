---
import { partners } from '@data/site';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const shown = compact ? partners.slice(0, 4) : partners;
---

<div class="partner-strip">
  {
    shown.map((partner) => (
      <article>
        <h3>{partner.name}</h3>
        <p>{partner.role}</p>
        {partner.href && <a href={partner.href} target="_blank" rel="noreferrer">Open partner site</a>}
      </article>
    ))
  }
</div>
