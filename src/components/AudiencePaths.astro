---
import { audiencePaths } from '@data/site';
import { withBase } from '@utils/urls';
---

<div class="audience-dossier">
  {
    audiencePaths.map((path, index) => (
      <article class="audience-panel">
        <div class="audience-panel__index">{String(index + 1).padStart(2, '0')}</div>
        <div>
          <p class="small-label">{path.audience}</p>
          <h3>{path.title}</h3>
          <p>{path.text}</p>
        </div>
        <a href={withBase(path.href)}>{path.action}</a>
      </article>
    ))
  }
</div>
