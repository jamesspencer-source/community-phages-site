---
import PageHero from '@components/PageHero.astro';
import PartnerStrip from '@components/PartnerStrip.astro';
import InsetFigure from '@components/InsetFigure.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Partners"
  description="The HMS, RCC, sponsor, mentor, and field-site partners that make Community Phages possible."
>
  <PageHero
    title="The partners who make the summer possible."
    text="Community Phages depends on RCC student support, HMS mentorship, sponsor generosity, field access, lab space, reagents, microscopy, sequencing, PhagesDB records, and poster sessions."
    actions={[
      { label: 'Explore the program', href: '/program/' },
      { label: 'Student information', href: '/students/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>Public partner roles.</h2>
      <p>
        This page summarizes the public roles: student recruitment and support, HMS lab teaching, program funding, supplies, field access, and scientific resources.
      </p>
    </div>
    <PartnerStrip />
  </section>

  <section class="section section--band">
    <div class="section-heading">
      <h2>Why partnership matters.</h2>
      <p>
        Partners make the program paid, mentored, and scientifically real. They help students get from a first day in the lab to field samples, phage isolates, sequencing data, and a final poster.
      </p>
    </div>
    <div class="journey journey--compact">
      <article class="journey-card">
        <div class="journey-card__marker"><span>R</span></div>
        <h3>Recruitment and access</h3>
        <p>RCC connections help the program reach students who can benefit from a first research experience.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>M</span></div>
        <h3>Mentorship</h3>
        <p>HMS instructors turn working research spaces into a supported learning environment.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>S</span></div>
        <h3>Support</h3>
        <p>Sponsors and program supporters help sustain student pay, supplies, field trips, and scientific resources.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>P</span></div>
        <h3>Public science</h3>
        <p>Repositories, poster sessions, and community events make student work visible beyond the classroom.</p>
      </article>
    </div>
    <div class="inset-row inset-row--after inset-row--compact">
      <InsetFigure
        src="/assets/neb-logo.png"
        alt="New England Biolabs logo"
        label="Support"
        caption="The old public site acknowledged New England Biolabs support; partner recognition remains part of the public site."
        tone="logo"
      />
    </div>
  </section>
</BaseLayout>
