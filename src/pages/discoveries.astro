---
import DiscoveryShowcase from '@components/DiscoveryShowcase.astro';
import InsetFigure from '@components/InsetFigure.astro';
import PageHero from '@components/PageHero.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/urls';
---

<BaseLayout
  title="Discoveries"
  description="Published Community Phages discoveries, posters, and phage records."
>
  <PageHero
    title="Phages from the summer."
    text="Students move from environmental samples to phage names, images, genomes, figures, and public records. This page highlights published discovery material from the program."
    actions={[
      { label: 'Open PhagesDB Harvard page', href: 'https://phagesdb.org/institutions/HARV/' },
      { label: 'Browse resources', href: '/resources/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>Published phage records.</h2>
      <p>
        Community Phages discoveries can be represented on PhagesDB once records are ready. The emphasis here is on isolates, methods, figures, and scientific context.
      </p>
    </div>
    <DiscoveryShowcase />
  </section>

  <section class="section section--band">
    <div class="section-heading">
      <h2>From sample to poster claim.</h2>
      <p>
        The scientific output is more than a name. Students learn how to turn observations into figures, claims, comparisons, and a presentation for a real audience.
      </p>
    </div>
    <div class="journey journey--compact">
      <article class="journey-card">
        <div class="journey-card__marker"><span>1</span></div>
        <h3>Environmental sample</h3>
        <p>Students collect soil or water and document where each sample came from.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>2</span></div>
        <h3>Plaque evidence</h3>
        <p>Clearings on bacterial lawns become the first visible hint of phage activity.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>3</span></div>
        <h3>Genome context</h3>
        <p>Sequencing and bioinformatics connect each phage to relatives, genes, and hypotheses.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>4</span></div>
        <h3>Poster story</h3>
        <p>Students assemble figures, practice explanations, and present what they learned.</p>
      </article>
    </div>
    <div class="inset-row inset-row--after">
      <InsetFigure
        src="/assets/hero-phage-world.png"
        alt="Illustrated phage specimens and plaque world"
        label="Discovery record"
        caption="The visual system stays specimen-based while the content points to public records and student-generated outputs."
        tone="graphic"
      />
    </div>
  </section>

  <section class="section">
    <div class="callout callout--wide">
      <div>
        <h2>What gets published</h2>
        <p>
          Discovery pages should highlight phages, methods, figures, poster claims, and public records. Student records and internal planning materials stay in program systems.
        </p>
      </div>
      <a class="button button--primary" href={withBase('/program/')}>See the program schedule</a>
    </div>
  </section>
</BaseLayout>
