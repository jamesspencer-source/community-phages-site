---
import AudiencePaths from '@components/AudiencePaths.astro';
import AtlasLabel from '@components/AtlasLabel.astro';
import DiscoveryShowcase from '@components/DiscoveryShowcase.astro';
import FactStrip from '@components/FactStrip.astro';
import GenomeTrace from '@components/GenomeTrace.astro';
import InsetFigure from '@components/InsetFigure.astro';
import MethodRail from '@components/MethodRail.astro';
import PageHero from '@components/PageHero.astro';
import SpecimenPlate from '@components/SpecimenPlate.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/urls';
---

<BaseLayout>
  <PageHero
    image
    title="An 8-week phage discovery program for RCC students and HMS instructors."
    text="Community Phages is a paid summer research internship at Harvard Medical School. Roxbury Community College students partner with researchers and instructors to isolate environmental bacteriophages, characterize what they find, and present the results."
    actions={[
      { label: 'For students', href: '/students/' },
      { label: 'For instructors', href: '/instructors/', variant: 'secondary' },
    ]}
  />
  <FactStrip />

  <section class="section">
    <div class="section-heading">
      <h2>Students and instructors work from the same protocols.</h2>
      <p>
        Students collect samples, test bacterial lawns, purify isolates, image phages, work with DNA, analyze sequence data, and build a poster from their own results. Instructors use the same methods and vocabulary to keep support consistent from week to week.
      </p>
    </div>
    <div class="story-spread">
      <div class="story-spread__main">
        <h3>From an environmental sample to a poster another scientist can read.</h3>
        <p>
          The program starts with practical lab skills and sample collection, then moves through plaques, purification, titers, microscopy, DNA extraction, restriction digest, genome analysis, and final presentation.
        </p>
        <div class="story-spread__graphics" aria-hidden="true">
          <SpecimenPlate compact tone="paper" />
          <GenomeTrace />
        </div>
      </div>
      <AudiencePaths />
    </div>
    <div class="inset-row inset-row--after">
      <InsetFigure
        src="/assets/hero-phage-world.png"
        alt="Illustrated phage specimens and plaque world used for Community Phages visual identity"
        label="Program image"
        caption="A public visual anchor for the discovery workflow: environmental samples, plaques, phages, genomes, and posters."
        tone="graphic"
      />
      <InsetFigure
        src="/assets/community-phages-archive-banner.png"
        alt="Community Phages banner artwork from the prior public program manual"
        label="Archive"
        caption="The prior public manual emphasized protocols and resources; this rebuild keeps that practical purpose."
        tone="graphic"
      />
    </div>
  </section>

  <section class="section section--band section--method">
    <div class="section-heading">
      <h2>The 8-week schedule.</h2>
      <p>
        The exact dates change each year, but the structure is stable: field sampling and bench skills first, plaques and lysates next, then micrographs, DNA, genome assembly, figures, and a final poster.
      </p>
    </div>
    <MethodRail limit={5} />
    <div class="callout callout--wide">
      <div>
        <h3>See the weekly plan</h3>
        <p>See how the summer is organized for students and for the instructors teaching each block of work.</p>
      </div>
      <a class="button button--primary" href={withBase('/program/')}>Program schedule</a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>Student discoveries become public phage records.</h2>
      <p>
        Plaques, phage names, genome assemblies, public records, and final posters make student work visible beyond the teaching bench.
      </p>
    </div>
    <DiscoveryShowcase />
  </section>

  <section class="section">
    <div class="callout callout--wide">
      <div>
        <h3>Protocols and teaching materials are on Resources.</h3>
        <p>Resources is the full working index for lab protocols, bioinformatics chapters, Day 1 material, notebook guidance, glossary, and instructor references.</p>
      </div>
      <a class="button button--primary" href={withBase('/resources/')}>Open resources</a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>The program runs on teaching time.</h2>
      <p>
        Faculty sponsors, program leads, instructors, mentors, lab staff, RCC partners, and supporters create the structure students move through every week.
      </p>
    </div>
    <div class="team-bridge">
      <article>
        <AtlasLabel code="Faculty" title="Scientific direction" text="Corynephage biology, bacterial evolution, immunity, and host-phage context." />
      </article>
      <article>
        <AtlasLabel code="Program" title="Daily teaching and operations" text="Lab setup, safety, sampling, bench work, bioinformatics, and poster support." />
      </article>
      <article>
        <AtlasLabel code="Mentors" title="Troubleshooting and student support" text="Graduate students, postdocs, staff, alumni, and partner instructors support the work." />
      </article>
    </div>
    <div class="callout callout--wide">
      <div>
        <h3>Meet the current team</h3>
        <p>Meet the faculty sponsors, program leads, instructors, and mentors behind the current program.</p>
      </div>
      <a class="button button--primary" href={withBase('/people/')}>People</a>
    </div>
  </section>
</BaseLayout>
