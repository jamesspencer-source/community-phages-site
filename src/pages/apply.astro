---
import PageHero from '@components/PageHero.astro';
import { applicationInfo } from '@data/site';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/urls';
---

<BaseLayout
  title="Apply"
  description="Application information for Roxbury Community College students interested in the Community Phages paid summer research program."
>
  <PageHero
    title="A first research lab can start here."
    text="Community Phages is for RCC students who are curious about biology, ready to learn at the bench, and able to commit to the full summer schedule."
    actions={[
      { label: 'Review the schedule', href: '/program/' },
      { label: 'See student outcomes', href: '/discoveries/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>Application snapshot.</h2>
      <p>
        Exact dates and links change each year. This page keeps the public expectations clear without publishing private setup details.
      </p>
    </div>
    <div class="audience-grid">
      <article class="audience-card">
        <span>01</span>
        <div>
          <p class="small-label">Status</p>
          <h3>When applications open</h3>
          <p>{applicationInfo.status}</p>
        </div>
      </article>
      <article class="audience-card">
        <span>02</span>
        <div>
          <p class="small-label">Fit</p>
          <h3>Who it is for</h3>
          <p>{applicationInfo.eligibility}</p>
        </div>
      </article>
      <article class="audience-card">
        <span>03</span>
        <div>
          <p class="small-label">Time</p>
          <h3>Expected commitment</h3>
          <p>{applicationInfo.schedule}</p>
        </div>
      </article>
    </div>
  </section>

  <section class="section section--band">
    <div class="section-heading">
      <h2>What students can expect.</h2>
      <p>
        The program is paid, mentored, and built around learning by doing. Students are supported through lab skills, scientific context, data analysis, and final communication.
      </p>
    </div>
    <div class="journey journey--compact">
      <article class="journey-card">
        <div class="journey-card__marker"><span>1</span></div>
        <h3>No phage background required</h3>
        <p>Instructors start with core skills and build vocabulary through experiments.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>2</span></div>
        <h3>Real research, not a demo</h3>
        <p>Students work with samples, plaques, strains, genomes, figures, and poster stories.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>3</span></div>
        <h3>Mentors close by</h3>
        <p>Graduate students, postdocs, staff, and faculty help students troubleshoot and interpret results.</p>
      </article>
      <article class="journey-card">
        <div class="journey-card__marker"><span>4</span></div>
        <h3>A public finish line</h3>
        <p>The summer ends with posters and, where ready, phage records that connect to public science.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="callout callout--wide">
      <div>
        <h2>Annual update note</h2>
        <p>{applicationInfo.note}</p>
      </div>
      <a class="button button--secondary" href={withBase('/partners/')}>See who supports the program</a>
    </div>
  </section>
</BaseLayout>
