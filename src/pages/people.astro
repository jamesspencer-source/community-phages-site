---
import PageHero from '@components/PageHero.astro';
import PeopleDirectory from '@components/PeopleDirectory.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="People"
  description="Current Community Phages faculty sponsors, program leaders, instructors, and mentors."
>
  <PageHero
    title="Faculty, staff, instructors, and mentors."
    text="The current Community Phages team includes HMS faculty sponsors, program leads, lead instructors, graduate students, postdocs, staff, alumni, and partner instructors."
    actions={[
      { label: 'Program timeline', href: '/program/' },
      { label: 'Resources', href: '/resources/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>Current team.</h2>
      <p>
        Faculty sponsors provide scientific context and lab support. Program leads organize the summer. Instructors and mentors work with students on protocols, data analysis, and posters.
      </p>
    </div>
    <PeopleDirectory />
  </section>
</BaseLayout>
