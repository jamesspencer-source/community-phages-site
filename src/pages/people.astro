---
import PageHero from '@components/PageHero.astro';
import PeopleDirectory from '@components/PeopleDirectory.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="People"
  description="Current Community Phages faculty sponsors, program leaders, instructors, and mentors."
>
  <PageHero
    title="The people teaching the program."
    text="Community Phages is taught by faculty sponsors, program leaders, lead instructors, graduate students, postdocs, staff, and alumni. The page is organized by teaching role so students and prospective instructors can see how the program works."
    actions={[
      { label: 'Program timeline', href: '/program/' },
      { label: 'Resources', href: '/resources/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>A teaching team, not just a directory.</h2>
      <p>
        Faculty set scientific context, program leads keep the summer running, and mentors help students move from bench work to genome analysis and posters.
      </p>
    </div>
    <PeopleDirectory />
  </section>
</BaseLayout>
