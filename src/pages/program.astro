---
import FactStrip from '@components/FactStrip.astro';
import PageHero from '@components/PageHero.astro';
import ProgramNotebookTimeline from '@components/ProgramNotebookTimeline.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/urls';
---

<BaseLayout
  title="Program"
  description="The Community Phages program arc from lab bootcamp and field sampling to phage discovery, sequencing, bioinformatics, and final posters."
>
  <PageHero
    title="Eight weeks from sample to poster."
    text="The calendar changes each year, but the summer follows a practical research sequence: safety and pipetting, environmental sampling, plaques, purification, titers, microscopy, DNA, genome comparisons, and final posters."
    actions={[
      { label: 'Student information', href: '/students/' },
      { label: 'Instructor information', href: '/instructors/', variant: 'secondary' },
    ]}
  />
  <FactStrip />

  <section class="section section--band">
    <div class="section-heading">
      <h2>From field sampling to public explanation.</h2>
      <p>
        Students move from learning core techniques to producing data they can explain. Instructors move through the same sequence, using the public protocols to keep handoffs and expectations consistent.
      </p>
    </div>
    <ProgramNotebookTimeline />
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>The day has a repeatable lab rhythm.</h2>
      <p>
        Students are usually on campus Monday-Thursday from 9am-2pm. Most days combine a short setup discussion, bench work or bioinformatics, notebook/data time, and a closeout conversation.
      </p>
    </div>
    <div class="lab-rhythm">
      <article>
        <span>Morning</span>
        <h3>Frame the experiment</h3>
        <p>Connect the day’s protocol to host bacteria, phage biology, or the poster story students are building.</p>
      </article>
      <article>
        <span>Midday</span>
        <h3>Run the work</h3>
        <p>Plate samples, pick plaques, prepare lysates, run gels, image phages, compare strains, or analyze sequence data.</p>
      </article>
      <article>
        <span>Close</span>
        <h3>Record and interpret</h3>
        <p>Notebook entries, calculations, figure sketches, and group discussion keep the research story moving.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="callout callout--wide">
      <div>
        <h2>Every method points back to the isolate.</h2>
        <p>
          Students collect samples, make measurements, name discoveries, learn the language of phage biology, and build a scientific narrative from their own data.
        </p>
      </div>
      <a class="button button--primary" href={withBase('/discoveries/')}>See discoveries</a>
    </div>
  </section>
</BaseLayout>
