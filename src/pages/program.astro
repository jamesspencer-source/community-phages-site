---
import FactStrip from '@components/FactStrip.astro';
import InsetFigure from '@components/InsetFigure.astro';
import PageHero from '@components/PageHero.astro';
import ProgramNotebookTimeline from '@components/ProgramNotebookTimeline.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/urls';
---

<BaseLayout
  title="Program"
  description="The Community Phages summer program from lab bootcamp and field sampling to phage discovery, sequencing, bioinformatics, and final posters."
>
  <PageHero
    title="Eight weeks from sample to poster."
    text="The calendar changes each year, but the summer follows a practical weekly plan: safety and pipetting, environmental sampling, plaques, purification, titers, microscopy, DNA, genome comparisons, and final posters."
    actions={[
      { label: 'Student information', href: '/students/' },
      { label: 'Instructor information', href: '/instructors/', variant: 'secondary' },
    ]}
  />
  <FactStrip />

  <section class="section section--band">
    <div class="section-heading">
      <h2>From field sampling to final poster.</h2>
      <p>
        Students move from learning core techniques to producing data they can explain. Instructors use the same protocols so handoffs and expectations stay consistent.
      </p>
    </div>
    <ProgramNotebookTimeline />
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>A typical lab day.</h2>
      <p>
        Students are usually on campus Monday-Thursday from 9am-2pm. Most days include a short setup discussion, bench work or bioinformatics, notebook/data time, and a closeout conversation.
      </p>
    </div>
    <div class="lab-rhythm">
      <article>
        <span>Morning</span>
        <h3>Set up the experiment</h3>
        <p>Review the protocol, the expected result, and how the work relates to host bacteria or phage biology.</p>
      </article>
      <article>
        <span>Midday</span>
        <h3>Run the work</h3>
        <p>Plate samples, pick plaques, prepare lysates, run gels, image phages, compare strains, or analyze sequence data.</p>
      </article>
      <article>
        <span>Close</span>
        <h3>Record and interpret</h3>
        <p>Record observations, calculations, gels, plaques, images, and next steps while the work is still fresh.</p>
      </article>
    </div>
    <div class="inset-row inset-row--after">
      <InsetFigure
        src="/assets/hero-phage-world.png"
        alt="Illustrated phage specimens and plaques"
        label="Workflow"
        caption="Sample, plaque, isolate, image, sequence, explain."
        tone="graphic"
      />
    </div>
  </section>

  <section class="section">
    <div class="callout callout--wide">
      <div>
        <h2>Methods stay tied to a phage isolate.</h2>
        <p>
          Students collect samples, purify phages, document measurements, analyze DNA sequence when available, and use those data in final posters.
        </p>
      </div>
      <a class="button button--primary" href={withBase('/discoveries/')}>Discoveries</a>
    </div>
  </section>
</BaseLayout>
