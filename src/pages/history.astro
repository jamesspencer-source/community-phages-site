---
import PageHero from '@components/PageHero.astro';
import YearHistory from '@components/YearHistory.astro';
import InsetFigure from '@components/InsetFigure.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { withBase } from '@utils/urls';
---

<BaseLayout
  title="History"
  description="Community Phages program history, mission, and acknowledgments."
>
  <PageHero
    title="A program built year by year."
    text="Community Phages began as a discovery-based summer program and now includes an 8-week RCC-HMS internship, public protocols, instructor teams, PhagesDB records, partner visits, and student poster sessions."
    actions={[
      { label: 'Meet the team', href: '/people/' },
      { label: 'Open resources', href: '/resources/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>Program history.</h2>
      <p>
        Prior program pages are summarized here so the site keeps institutional memory as the program changes year to year.
      </p>
    </div>
    <div class="inset-row">
      <InsetFigure
        src="/assets/community-phages-archive-banner.png"
        alt="Community Phages banner artwork from the prior public program website"
        label="Archive"
        caption="The previous public site was a protocol manual for the summer program; the history page keeps that continuity visible."
        tone="graphic"
      />
    </div>
    <YearHistory />
  </section>

  <section class="section section--band">
    <div class="section-heading">
      <h2>Diversity and equity mission.</h2>
      <p>
        Community Phages is designed to make an HMS research experience accessible to RCC students through paid time in the lab, close mentoring, clear protocols, and a teaching team that expects students to contribute real data.
      </p>
    </div>
    <div class="callout callout--wide">
      <div>
        <h3>Acknowledgments</h3>
        <p>
          The program was inspired by HHMI SEA-PHAGES, with protocols and materials adapted or reproduced with permission. The site also recognizes the HMS, RCC, sponsor, field-site, and mentor communities that keep the program running.
        </p>
      </div>
      <a class="button button--primary" href={withBase('/partners/')}>Partners</a>
    </div>
  </section>
</BaseLayout>
