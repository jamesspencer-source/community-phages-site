---
import PageHero from '@components/PageHero.astro';
import ProtocolIndex from '@components/ProtocolIndex.astro';
import ResourceManual from '@components/ResourceManual.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resources"
  description="Public Community Phages protocols, bioinformatics materials, schedule references, and instructor-friendly resources."
>
  <PageHero
    title="The public manual."
    text="Lab protocols, bioinformatics chapters, Day 1 setup, notebook guidance, glossary, and instructor/public materials are indexed as a working reference."
    actions={[
      { label: 'Program schedule', href: '/program/' },
      { label: 'Instructor information', href: '/instructors/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>Indexed by the work students actually do.</h2>
      <p>
        The structure mirrors the prior site’s depth while making it easier to move from bench protocol to genome analysis to poster preparation.
      </p>
    </div>
    <ProtocolIndex />
    <ResourceManual />
  </section>

  <section class="section" id="instructors">
    <div class="section-heading">
      <h2>Instructor use stays practical.</h2>
      <p>
        Instructor references are included in the manual index so new mentors can see the sequence, vocabulary, and expectations before they teach.
      </p>
    </div>
    <div class="lab-rhythm">
      <article>
        <span>Before week 1</span>
        <h3>Review the sequence</h3>
        <p>Use the program page to orient new instructors to the full discovery arc and recurring daily rhythm.</p>
      </article>
      <article>
        <span>During lab</span>
        <h3>Keep protocols consistent</h3>
        <p>Point students to a shared public protocol language for pipetting, lawns, purification, titers, DNA, and bioinformatics.</p>
      </article>
      <article>
        <span>Before posters</span>
        <h3>Turn data into claims</h3>
        <p>Use discoveries and resource links to guide figure-making, PhagesDB context, and final presentation practice.</p>
      </article>
    </div>
  </section>
</BaseLayout>
