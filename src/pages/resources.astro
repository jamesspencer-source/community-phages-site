---
import PageHero from '@components/PageHero.astro';
import ProtocolIndex from '@components/ProtocolIndex.astro';
import ResourceManual from '@components/ResourceManual.astro';
import InsetFigure from '@components/InsetFigure.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resources"
  description="Public Community Phages protocols, bioinformatics materials, schedule references, and instructor-friendly resources."
>
  <PageHero
    title="Protocols and references."
    text="Lab protocols, bioinformatics chapters, Day 1 setup, notebook guidance, glossary, and instructor materials."
    actions={[
      { label: 'Program schedule', href: '/program/' },
      { label: 'Instructor information', href: '/instructors/', variant: 'secondary' },
    ]}
  />

  <section class="section">
    <div class="section-heading">
      <h2>Indexed by the work students actually do.</h2>
      <p>
        Bench protocols, genome-analysis chapters, notebook guidance, glossary entries, and poster support.
      </p>
    </div>
    <div class="inset-row">
      <InsetFigure
        src="/assets/community-phages-archive-banner.png"
        alt="Community Phages banner"
        label="Community Phages"
        caption="Program protocols and reference material."
        tone="graphic"
      />
    </div>
    <ProtocolIndex />
    <ResourceManual />
  </section>

  <section class="section" id="instructors">
    <div class="section-heading">
      <h2>Instructor use stays practical.</h2>
      <p>
        Shared vocabulary, expectations, and teaching materials for instructors joining the summer.
      </p>
    </div>
    <div class="lab-rhythm">
      <article>
        <span>Before week 1</span>
        <h3>Review the weekly plan</h3>
        <p>The 8-week schedule, daily blocks, and current-year dates.</p>
      </article>
      <article>
        <span>During lab</span>
        <h3>Keep protocols consistent</h3>
        <p>Shared language for pipetting, lawns, purification, titers, DNA, and bioinformatics.</p>
      </article>
      <article>
        <span>Before posters</span>
        <h3>Turn data into claims</h3>
        <p>Figure-making, PhagesDB context, and final presentation practice.</p>
      </article>
    </div>
  </section>
</BaseLayout>
